rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /{document=**} {
      allow read, write: if false;
    }

    // Helper: accepte auth.uid OU auth.token.email (backward compat)
    function isOwner(userId) {
      return userId == request.auth.uid || userId == request.auth.token.email;
    }

    // ── UTILISATEURS ──
    match /users/{userId} {
      allow read: if request.auth.uid == userId || request.auth.token.admin == true;
      allow create: if request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['prenom', 'nom', 'email', 'role', 'createdAt', 'photoURL'])
        && request.resource.data.prenom is string
        && request.resource.data.prenom.size() >= 1
        && request.resource.data.prenom.size() <= 50
        && request.resource.data.nom is string
        && request.resource.data.nom.size() >= 1
        && request.resource.data.nom.size() <= 50
        && request.resource.data.email is string
        && request.resource.data.email.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$')
        && request.resource.data.role in ['student', 'teacher']
        && (!request.resource.data.keys().hasAny(['photoURL']) || request.resource.data.photoURL is string)
        && (!request.resource.data.keys().hasAny(['createdAt']) || request.resource.data.createdAt == request.time);
      allow update: if request.auth.uid == userId
        && request.resource.data.keys().size() <= 7
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['email', 'createdAt', 'role'])
        && (!request.resource.data.keys().hasAny(['prenom']) || request.resource.data.prenom is string)
        && (!request.resource.data.keys().hasAny(['prenom']) || request.resource.data.prenom.size() >= 1)
        && (!request.resource.data.keys().hasAny(['prenom']) || request.resource.data.prenom.size() <= 50)
        && (!request.resource.data.keys().hasAny(['nom']) || request.resource.data.nom is string)
        && (!request.resource.data.keys().hasAny(['nom']) || request.resource.data.nom.size() >= 1)
        && (!request.resource.data.keys().hasAny(['nom']) || request.resource.data.nom.size() <= 50)
        && (!request.resource.data.keys().hasAny(['photoURL']) || request.resource.data.photoURL is string)
        && (!request.resource.data.keys().hasAny(['avatar']) || request.resource.data.avatar is string)
        && (!request.resource.data.keys().hasAny(['bio']) || request.resource.data.bio is string)
        && (!request.resource.data.keys().hasAny(['bio']) || request.resource.data.bio.size() <= 500)
        && (!request.resource.data.keys().hasAny(['pseudo']) || request.resource.data.pseudo is string)
        && (!request.resource.data.keys().hasAny(['pseudo']) || request.resource.data.pseudo.size() <= 30);
      allow delete: if request.auth.uid == userId;
    }

    // ── STATS UTILISATEUR (XP / Niveau) ──
    match /userStats/{userId} {
      allow read: if request.auth.uid == userId;
      allow create: if request.auth.uid == userId
        && !exists(/databases/$(database)/documents/userStats/$(userId))
        && request.resource.data.keys().hasOnly(['xp', 'level', 'streak', 'lastActive', 'totalActions', 'updatedAt'])
        && request.resource.data.xp is number
        && request.resource.data.xp >= 0
        && request.resource.data.xp <= 100
        && request.resource.data.level is number
        && request.resource.data.level >= 1
        && request.resource.data.streak is number
        && request.resource.data.streak >= 0
        && request.resource.data.lastActive is string
        && request.resource.data.totalActions is number
        && request.resource.data.totalActions >= 0
        && request.resource.data.updatedAt == request.time;
      allow update: if request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['xp', 'level', 'streak', 'lastActive', 'totalActions', 'updatedAt'])
        && request.resource.data.xp is number
        && request.resource.data.xp >= (resource.data.xp != null ? resource.data.xp : 0)
        && request.resource.data.xp <= (resource.data.xp != null ? resource.data.xp : 0) + 100
        && request.resource.data.level is number
        && request.resource.data.streak is number
        && request.resource.data.lastActive is string
        && request.resource.data.totalActions is number
        && request.resource.data.updatedAt == request.time;
    }

    // ── COURS ──
    match /cours/{document} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.token.email_verified == true
        && isOwner(request.resource.data.userId)
        && request.resource.data.keys().hasOnly(['title', 'filiere', 'annee', 'specialite', 'matiere', 'classId', 'matiereLabel', 'matiereIcon', 'matiereColor', 'description', 'fileUrl', 'fileName', 'dateAdded'])
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 1
        && request.resource.data.title.size() <= 100
        && request.resource.data.fileUrl is string
        && request.resource.data.fileUrl.matches('^https://(drive\\.google\\.com|onedrive\\.live\\.com|api\\.notion\\.com|docs\\.google\\.com|github\\.com|media\\.education\\.gouv\\.fr)/.*')
        && request.resource.data.matiere is string
        && request.resource.data.filiere is string
        && request.resource.data.annee is string
        && request.resource.data.dateAdded == request.time;
      allow update: if request.auth != null
        && isOwner(resource.data.userId)
        && request.resource.data.keys().size() <= 14
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['dateAdded', 'userId'])
        && (!request.resource.data.keys().hasAny(['title']) || request.resource.data.title is string)
        && (!request.resource.data.keys().hasAny(['title']) || request.resource.data.title.size() >= 1)
        && (!request.resource.data.keys().hasAny(['title']) || request.resource.data.title.size() <= 100)
        && (!request.resource.data.keys().hasAny(['fileUrl']) || request.resource.data.fileUrl is string)
        && (!request.resource.data.keys().hasAny(['fileUrl']) || request.resource.data.fileUrl.matches('^https://(drive\\.google\\.com|onedrive\\.live\\.com|api\\.notion\\.com|docs\\.google\\.com|github\\.com|media\\.education\\.gouv\\.fr)/.*'))
        && (!request.resource.data.keys().hasAny(['matiere']) || request.resource.data.matiere is string)
        && (!request.resource.data.keys().hasAny(['filiere']) || request.resource.data.filiere is string)
        && (!request.resource.data.keys().hasAny(['annee']) || request.resource.data.annee is string);
      allow delete: if request.auth != null
        && isOwner(resource.data.userId);
    }

    // ── CLASSES ──
    match /classes/{classId} {
      allow read: if request.auth != null
        && (resource.data.creatorId == request.auth.uid
          || request.auth.token.admin == true
          || exists(/databases/$(database)/documents/classMembers/$(request.auth.uid + '_' + classId)));
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['name', 'code', 'creatorId', 'memberCount', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 50
        && request.resource.data.code is string
        && request.resource.data.code.size() == 6
        && request.resource.data.creatorId == request.auth.uid
        && request.resource.data.memberCount == 1
        && request.resource.data.createdAt == request.time;
      allow update: if request.auth != null
        && resource.data.creatorId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'memberCount'])
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['code'])
        && (!request.resource.data.keys().hasAny(['memberCount']) || request.resource.data.memberCount is number);
      allow delete: if request.auth != null
        && resource.data.creatorId == request.auth.uid;
    }

    // ── MEMBRES DE CLASSE ──
    match /classMembers/{memberId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && memberId == request.auth.uid + '_' + request.resource.data.classId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.classId is string
        && request.resource.data.keys().hasOnly(['userId', 'classId', 'prenom', 'nom'])
        && exists(/databases/$(database)/documents/classes/$(request.resource.data.classId));
      allow delete: if request.auth != null && (
        resource.data.userId == request.auth.uid
        || get(/databases/$(database)/documents/classes/$(resource.data.classId)).data.creatorId == request.auth.uid
      );
    }

    // ── COOLDOWN CHAT ──
    match /classChatCooldowns/{userId} {
      allow read: if false;
      allow create: if request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['lastMessageAt', 'classId'])
        && request.resource.data.lastMessageAt == request.time
        && request.resource.data.classId is string;
      allow update: if request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['lastMessageAt', 'classId'])
        && request.resource.data.lastMessageAt == request.time
        && request.resource.data.classId is string;
      allow delete: if false;
    }

    // ── MESSAGES DE CLASSE (CHAT) ──
    match /classMessages/{document} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.classId is string
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 500
        && request.resource.data.text.size() >= 1
        && request.resource.data.userEmail is string
        && request.resource.data.userName is string
        && request.resource.data.keys().hasOnly(['userId', 'classId', 'text', 'timestamp', 'userEmail', 'userName'])
        && request.resource.data.timestamp == request.time
        && (
          !exists(/databases/$(database)/documents/classChatCooldowns/$(request.auth.uid))
          || (request.time - get(/databases/$(database)/documents/classChatCooldowns/$(request.auth.uid)).data.lastMessageAt) >= duration.value(5, 's')
        );
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.time - resource.data.timestamp < duration.value(24, 'h');
    }

    // ── COMMENTAIRES ──
    match /comments/{document} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && isOwner(request.resource.data.userId)
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 1000
        && request.resource.data.keys().hasOnly(['userId', 'text', 'timestamp', 'prenom', 'nom'])
        && request.resource.data.timestamp == request.time;
      allow delete: if request.auth != null
        && isOwner(resource.data.userId)
        && request.time - resource.data.timestamp < duration.value(24, 'h');
    }

    // ── RÉSULTATS QUIZ ──
    match /quizResults/{document} {
      allow create: if request.auth != null
        && isOwner(request.resource.data.userId)
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.score <= 100
        && request.resource.data.total is number
        && request.resource.data.total >= 1
        && request.resource.data.keys().hasOnly(['userId', 'score', 'total', 'timestamp', 'quizTitle', 'classId'])
        && request.resource.data.timestamp == request.time;
      allow read: if request.auth != null && (
        isOwner(resource.data.userId)
        || (resource.data.classId is string
          && get(/databases/$(database)/documents/classes/$(resource.data.classId)).data.creatorId == request.auth.uid)
      );
    }

    // ── NOTIFICATIONS ──
    match /notifications/{document} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.type is string
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 100
        && request.resource.data.body is string
        && request.resource.data.body.size() <= 200
        && request.resource.data.keys().hasOnly(['userId', 'type', 'title', 'body', 'createdAt', 'read'])
        && request.resource.data.createdAt == request.time;
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasOnly(['read']);
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // ── PROGRÈS COURS ──
    match /courseProgress/{document} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId
        && request.resource.data.keys().hasOnly(['userId', 'completed', 'updatedAt', 'courseId'])
        && request.resource.data.completed is bool
        && request.resource.data.updatedAt == request.time;
      allow update: if request.auth != null
        && request.auth.uid == resource.data.userId
        && request.resource.data.keys().size() <= 4
        && request.resource.data.completed is bool
        && request.resource.data.updatedAt == request.time;
      allow delete: if false;
    }

    // ── STATS PUBLIQUES ──
    match /_stats/{document} {
      allow read: if true;
      allow write: if request.auth.token.admin == true
        && request.resource.data.keys().hasOnly(['users', 'cours', 'classes', 'updatedAt']);
    }

  }
}
